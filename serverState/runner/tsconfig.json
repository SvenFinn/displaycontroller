        "target": "ES2023",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "outDir": "./dist",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "types": ["node"]
    },
    "include": [
        "src/**/*.ts"
    ],
}