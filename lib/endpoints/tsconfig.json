{
    "compilerOptions": {
        "target": "ES2023",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "outDir": "./dist",
        "declaration": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "plugins": [
            {
                "transform": "typia/lib/transform",
            },
        ],
        "strictNullChecks": true,
        "types": ["node"],
    },
    "include": ["src/**/*.ts"],
}
